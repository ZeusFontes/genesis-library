# =============================================================================
# GÊNESIS — Variáveis de Ambiente
# =============================================================================

# TMDB — The Movie Database (https://www.themoviedb.org/settings/api)
TMDB_BEARER_TOKEN=seu_bearer_token_tmdb_aqui

# Google Books API (https://console.cloud.google.com)
GOOGLE_BOOKS_API_KEY=sua_chave_google_books_aqui

# OMDB API — para nota do Rotten Tomatoes (OPCIONAL, grátis em https://www.omdbapi.com/apikey.aspx)
# Sem esta chave, apenas a nota IMDB aparece. Com ela, a nota RT também é exibida.
OMDB_API_KEY=sua_chave_omdb_aqui

# Servidor
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
